{
  "name": "@bunli/store",
  "version": "0.1.0",
  "description": "Typed file-backed persistence for Bunli CLI apps",
  "keywords": [
    "bunli",
    "cli",
    "config",
    "persistence",
    "store",
    "typed",
    "xdg"
  ],
  "homepage": "https://github.com/AryaLabsHQ/bunli#readme",
  "bugs": {
    "url": "https://github.com/AryaLabsHQ/bunli/issues"
  },
  "license": "MIT",
  "author": "Arya Labs, Inc.",
  "repository": {
    "type": "git",
    "url": "https://github.com/AryaLabsHQ/bunli.git",
    "directory": "packages/store"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun scripts/build.ts && bun run tsc",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@bunli/utils": "workspace:^",
    "better-result": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "bun": ">=1.3.7"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
