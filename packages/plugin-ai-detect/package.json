{
  "name": "@bunli/plugin-ai-detect",
  "version": "0.6.4",
  "description": "AI agent detection plugin for Bunli - detects Claude, Cursor, Copilot and other AI coding assistants",
  "keywords": [
    "ai",
    "bunli",
    "claude",
    "cli",
    "copilot",
    "cursor",
    "plugin"
  ],
  "license": "MIT",
  "author": "Bunli Team",
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "bun run scripts/build.ts",
    "typecheck": "tsgo --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@bunli/core": "workspace:^"
  },
  "devDependencies": {
    "@tsconfig/bun": "catalog:",
    "@types/bun": "catalog:",
    "typescript": "catalog:"
  }
}
