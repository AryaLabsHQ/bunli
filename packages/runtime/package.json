{
  "name": "@bunli/runtime",
  "version": "0.3.1",
  "description": "Runtime renderer and prompt primitives for Bunli",
  "keywords": [
    "bunli",
    "prompt",
    "runtime",
    "terminal",
    "tui"
  ],
  "license": "MIT",
  "author": "Bunli Contributors",
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./app": {
      "types": "./dist/app.d.ts",
      "default": "./src/app.ts"
    },
    "./renderer": {
      "types": "./dist/renderer.d.ts",
      "default": "./src/renderer.tsx"
    },
    "./prompt": {
      "types": "./dist/prompt/index.d.ts",
      "default": "./src/prompt/index.ts"
    },
    "./options": {
      "types": "./dist/options.d.ts",
      "default": "./src/options.ts"
    },
    "./events": {
      "types": "./dist/events.d.ts",
      "default": "./src/events.ts"
    },
    "./transport": {
      "types": "./dist/transport.d.ts",
      "default": "./src/transport.ts"
    },
    "./image": {
      "types": "./dist/image/index.d.ts",
      "default": "./src/image/index.ts"
    }
  },
  "scripts": {
    "build": "bun run scripts/build.ts && tsgo",
    "test": "bun test",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@opentui/core": "catalog:",
    "@opentui/react": "catalog:",
    "@standard-schema/spec": "catalog:",
    "@standard-schema/utils": "catalog:",
    "better-result": "catalog:",
    "debug": "catalog:",
    "fuse.js": "^7.1.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@tsconfig/bun": "catalog:",
    "@types/bun": "catalog:",
    "@types/debug": "catalog:",
    "@types/react": "catalog:",
    "react": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@opentui/core": "catalog:",
    "react": "catalog:"
  }
}
