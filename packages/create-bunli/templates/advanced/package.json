{
  "name": "{{name}}",
  "version": "0.1.0",
  "description": "{{description}}",
  "license": "{{license}}",
  "author": "{{author}}",
  "bin": {
    "{{name}}": "./dist/index.js"
  },
  "type": "module",
  "scripts": {
    "postinstall": "bunli generate",
    "dev": "bun run src/index.ts",
    "build": "bunli build",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsgo --noEmit",
    "lint": "tsc --noEmit",
    "prepare": "bun run build"
  },
  "dependencies": {
    "@bunli/core": "latest",
    "@bunli/utils": "latest",
    "better-result": "^2.7.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@bunli/test": "latest",
    "@tsconfig/bun": "1.0.10",
    "@types/bun": "latest",
    "bunli": "latest",
    "typescript": "^5.0.0"
  },
  "bunli": {
    "entry": "./src/index.ts",
    "outDir": "./dist",
    "external": [
      "@bunli/core",
      "@bunli/utils",
      "zod"
    ]
  }
}
