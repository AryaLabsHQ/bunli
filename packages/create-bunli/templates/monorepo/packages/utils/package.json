{
  "name": "@{{name}}/utils",
  "version": "0.1.0",
  "description": "Shared utilities for {{name}}",
  "license": "MIT",
  "author": "{{author}}",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "bun scripts/build.ts && bun run tsgo",
    "test": "bun test",
    "typecheck": "tsgo --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@tsconfig/bun": "catalog:",
    "@types/bun": "latest",
    "typescript": "^5.0.0"
  }
}
