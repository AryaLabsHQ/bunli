{
  "name": "@{{name}}/cli",
  "version": "0.1.0",
  "description": "CLI for {{name}}",
  "license": "MIT",
  "author": "{{author}}",
  "bin": {
    "{{name}}": "./dist/index.js"
  },
  "type": "module",
  "scripts": {
    "postinstall": "bunli generate",
    "dev": "bun run src/index.ts",
    "build": "bunli build",
    "test": "bun test",
    "typecheck": "tsgo --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@bunli/core": "latest",
    "@{{name}}/core": "workspace:^",
    "@{{name}}/utils": "workspace:^"
  },
  "devDependencies": {
    "@bunli/test": "latest",
    "@tsconfig/bun": "catalog:",
    "@types/bun": "latest",
    "bunli": "latest",
    "typescript": "^5.0.0"
  },
  "bunli": {
    "entry": "./src/index.ts",
    "outDir": "./dist",
    "external": [
      "@bunli/core",
      "@{{name}}/core",
      "@{{name}}/utils"
    ]
  }
}
