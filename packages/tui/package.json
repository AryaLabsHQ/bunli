{
  "name": "@bunli/tui",
  "version": "0.5.3",
  "description": "Terminal User Interface plugin for Bunli CLI framework",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./inline": {
      "types": "./dist/inline/index.d.ts",
      "default": "./src/inline/index.ts"
    },
    "./interactive": {
      "types": "./dist/interactive/index.d.ts",
      "default": "./src/interactive/index.tsx"
    },
    "./charts": {
      "types": "./dist/charts/index.d.ts",
      "default": "./src/charts/index.tsx"
    },
    "./utils/sync-batcher": {
      "types": "./dist/utils/sync-batcher.d.ts",
      "default": "./src/utils/sync-batcher.ts"
    }
  },
  "scripts": {
    "build": "bun run scripts/build.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bunli/runtime": "workspace:^",
    "@opentui/core": "catalog:",
    "@opentui/react": "catalog:",
    "@standard-schema/spec": "catalog:",
    "@standard-schema/utils": "catalog:",
    "debug": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@types/react": "catalog:",
    "react": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@opentui/core": "catalog:",
    "react": "catalog:"
  },
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "bunli",
    "cli",
    "tui",
    "terminal",
    "ui",
    "interactive"
  ],
  "author": "Bunli Contributors",
  "license": "MIT"
}
