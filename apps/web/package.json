{
  "name": "@bunli/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "portless run --name bunli vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "bun run cf-typegen && tsc --noEmit",
    "test": "bun test",
    "cf-typegen": "wrangler types --env-interface Env",
    "deploy": "bun run build && bun scripts/deploy.ts",
    "postinstall": "bun run cf-typegen"
  },
  "dependencies": {
    "@cloudflare/sandbox": "^0.7.1",
    "@hono/zod-validator": "^0.7.2",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.12",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-router": "^1.142.8",
    "@tanstack/react-start": "^1.142.8",
    "@tanstack/router-plugin": "^1.142.8",
    "better-auth": "^1.4.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fumadocs-core": "16.6.17",
    "fumadocs-mdx": "^14.1.0",
    "fumadocs-ui": "16.6.17",
    "ghostty-web": "^0.4.0",
    "hono": "^4.10.6",
    "lucide-react": "^0.577.0",
    "monaco-editor": "^0.55.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "^2.0.5",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.3.4",
    "tailwindcss": "^4.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.21.0",
    "@types/mdx": "^2.0.13",
    "@types/node": "24.10.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "react-grab": "^0.1.11",
    "typescript": "^5.8.3",
    "vite": "^7.3.0",
    "vite-tsconfig-paths": "^5.1.4",
    "wrangler": "^4.64.0"
  }
