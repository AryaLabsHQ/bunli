{
  "name": "@bunli/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "playground": "bun scripts/copy-playground-assets.ts",
    "dev": "bun run playground && portless run --name bunli vite dev",
    "build": "bun run playground && vite build",
    "build:production": "bun run playground && NODE_OPTIONS=--max-old-space-size=4096 vite build --mode production",
    "preview": "vite preview",
    "typecheck": "bun run cf-typegen && tsgo --noEmit",
    "test": "bun test",
    "cf-typegen": "wrangler types --env-interface Env",
    "deploy": "bun run build:production && wrangler deploy"
  },
  "dependencies": {
    "@base-ui/react": "^1.0.0",
    "@cloudflare/sandbox": "^0.7.1",
    "@hono/zod-validator": "^0.7.2",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-router": "^1.142.8",
    "@tanstack/react-start": "^1.142.8",
    "@tanstack/router-plugin": "^1.142.8",
    "better-auth": "^1.4.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fumadocs-core": "^16.7.6",
    "fumadocs-mdx": "^14.2.11",
    "fumadocs-ui": "npm:@fumadocs/base-ui@16.7.6",
    "ghostty-web": "^0.4.0",
    "hono": "^4.10.6",
    "lucide-react": "^0.577.0",
    "monaco-editor": "^0.55.1",
    "next-themes": "^0.4.6",
    "react": "catalog:",
    "react-dom": "19.2.4",
    "sonner": "^2.0.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.3.4",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.21.0",
    "@tsconfig/bun": "catalog:",
    "@types/mdx": "^2.0.13",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "react-grab": "^0.1.11",
    "typescript": "catalog:",
    "vite": "^7.3.0",
    "vite-tsconfig-paths": "^5.1.4",
    "wrangler": "^4.64.0"
  }
}
