# Public/base URLs
SITE_URL=http://localhost:3000
BETTER_AUTH_BASE_URL=http://localhost:3000

# Better Auth (required)
BETTER_AUTH_SECRET=replace-with-a-strong-random-secret
GITHUB_CLIENT_ID=replace-with-github-oauth-client-id
GITHUB_CLIENT_SECRET=replace-with-github-oauth-client-secret

# Workbench runtime defaults
WORKBENCH_WORKSPACE_DIR=/workspace/demo
WORKBENCH_SANDBOX_NETWORK=off
