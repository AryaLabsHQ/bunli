{
  "name": "bunli-monorepo",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/*",
      "examples/*",
      "apps/*"
    ],
    "catalog": {
      "@opentui/core": "^0.1.90",
      "@opentui/react": "^0.1.90",
      "@tsconfig/bun": "1.0.10",
      "@standard-schema/spec": "^1.1.0",
      "@standard-schema/utils": "^0.3.0",
      "@types/bun": "1.3.10",
      "@types/node": "24.10.1",
      "@types/react": "19.2.14",
      "better-result": "^2.7.0",
      "debug": "^4.4.3",
      "@types/debug": "^4.1.13",
      "react": "^19.2.4",
      "@typescript/native-preview": "7.0.0-dev.20260325.1",
      "typescript": "^6.0.2",
      "zod": "^4.3.6"
    }
  },
  "type": "module",
  "scripts": {
    "build": "turbo run build --filter='./packages/*'",
    "typecheck": "turbo run typecheck --filter='./packages/*' && bun run typecheck:scripts",
    "typecheck:scripts": "tsgo --noEmit",
    "test:coverage": "bun test --coverage --coverage-reporter=lcov --coverage-dir=coverage",
    "examples:generate": "turbo run generate --filter='@bunli-examples/*'",
    "examples:typecheck": "turbo run typecheck --filter='@bunli-examples/*'",
    "examples:build": "turbo run build --filter='@bunli-examples/*'",
    "clean": "bun scripts/clean.ts",
    "test": "bun test",
    "dev": "bun scripts/dev.ts",
    "release": "bun run release:prepare",
    "changeset": "bunx changeset",
    "changeset:version": "bunx changeset version",
    "changeset:publish": "bun run ci:publish",
    "release:prepare": "bun scripts/release-prepare.ts",
    "ci:version": "bun scripts/ci-version.ts",
    "ci:publish": "bun scripts/ci-publish.ts",
    "release:publish": "bun run build && bun run ci:publish",
    "typecheck:types": "vitest --run",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "devDependencies": {
    "@bunli/runtime": "workspace:^",
    "@bunli/tui": "workspace:^",
    "@changesets/cli": "^2.29.8",
    "@tsconfig/bun": "catalog:",
    "@types/bun": "catalog:",
    "@typescript/native-preview": "catalog:",
    "ai": "^6.0.72",
    "better-result": "catalog:",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "turbo": "^2.8.0",
    "typescript": "catalog:",
    "vitest": "^4.1.0"
  },
  "packageManager": "bun@1.3.10",
  "patchedDependencies": {
    "@bomb.sh/tab@0.0.13": "patches/@bomb.sh%2Ftab@0.0.13.patch"
  }
}
